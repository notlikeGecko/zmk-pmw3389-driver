menuconfig PMW3389
	bool "PMW3389 mouse optical sensor"
  select SPI
	help
	  Enable PMW3389 mouse optical sensor.

if PMW3389

config PMW3389_CPI
	int "PMW3389's default CPI"
	default 1500
	range 50 16000
	help
	  Default CPI value.

config PMW3389_CPI_DIVIDOR
	int "PMW3389's default CPI dividor"
	default 4
	range 1 12
	help
	  Default CPI dividor value.

config PMW3389_SNIPE_CPI
    int "PMW3389's CPI in snipe mode"
    default 200
    range 200 3200
    help
      Snipe CPI value, with 200 step

config PMW3389_SNIPE_CPI_DIVIDOR
    int "PMW3389's CPI dividor in snipe mode"
    default 1
    range 1 100
    help
      Snipe CPI dividor value.


config PMW3389_RUN_DOWNSHIFT_TIME_MS
	int "PMW3389's default RUN mode downshift time"
	default 500
	range 10 2550
	help
	  Default RUN mode downshift down time in milliseconds.
	  Time after which sensor goes from RUN to REST1 mode.

config PMW3389_REST1_DOWNSHIFT_TIME_MS
	int "PMW3389's default REST1 mode downshift time"
	default 9220
	range 320 81600
	help
	  Default REST1 mode downshift down time in milliseconds.
	  Time after which sensor goes from REST1 to REST2 mode.

config PMW3389_REST2_DOWNSHIFT_TIME_MS
	int "PMW3389's default REST2 mode downshift time"
	default 150000
	range 3200 816000
	help
	  Default REST2 mode downshift down time in milliseconds.
	  Time after which sensor goes from REST2 to REST3 mode.

choice
	prompt "Select PMW3389 sensor orientation"
	default PMW3389_ORIENTATION_0

config PMW3389_ORIENTATION_0
	bool "PMW3389 not rotated"

config PMW3389_ORIENTATION_90
	bool "PMW3389 rotated 90 deg clockwise"

config PMW3389_ORIENTATION_180
	bool "PMW3389 rotated 180 deg clockwise"

config PMW3389_ORIENTATION_270
	bool "PMW3389 rotated 270 deg clockwise"

endchoice

config PMW3389_INVERT_X
    bool "Invert the X axis of PMW3389 sensor"

config PMW3389_INVERT_Y
    bool "Invert the Y axis of PMW3389 sensor"

module = PMW3389
module-str = PMW3389
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"

endif #PMW3389
